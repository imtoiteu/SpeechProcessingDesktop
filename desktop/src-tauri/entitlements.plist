<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the signed macOS build. The audio-input
  entitlement lets the app capture the microphone under the hardened runtime
  (used by notarized/distributed .app/.dmg builds). Referenced from
  tauri.conf.json -> bundle.macOS.entitlements.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.device.audio-input</key>
    <true/>
  </dict>
</plist>
